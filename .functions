# vim: set filetype=sh :

g() {
  if [ "$#" -eq 0 ]; then
    git st
  else
    git $*
  fi
}

ali() {
  alias ${1:0:1}=${1}
}

termname() {
  printf '\033]2;%s\033\\' "$*"

}

zgen() {
  source "${HOME}/.zgen/zgen.zsh"
  zgen "$@"

}

y() {
  if [ "$#" -eq 0 ]; then
    yadm st
  else
    yadm $*
  fi
}

yw() {
  if [ "$#" -eq 0 ]; then
    yadm --yadm-dir "${HOME}/.config/yadm-w" --yadm-data "${HOME}/.local/share/yadm-w" st
  else
    yadm --yadm-dir "${HOME}/.config/yadm-w" --yadm-data "${HOME}/.local/share/yadm-w" $*
  fi

}

wp() {
    [ "${#}" -eq 0 ] && return

    [[ "${1}" =~ '^[0-9]$' ]] || return

    if [[ "${2}" == "" ]]; then
        wp_dir=~/Dropbox/Pictures/lorem
    else
        wp_dir="${2}"
    fi

    [ -d "${wp_dir}" ] || return

    sxiv -f -r -t "${wp_dir}" -o|head -1|xargs -r -I{} ln -sf {} ~/.local/share/background/${1}

    feh --bg-fill ~/.local/share/background/*
}

up() {
    curl -s -F"file=@${1}" https://0x0.st|tee /dev/tty|wl-copy
}

rcp() {
    src="${1}"
    dest="${2}"

    # if [[ "${dest}" == "" ]]; then
        # dest="${src}"
    # fi

    rsync -av --info=progress2 "${src}" "${dest}"
}

rcpn() {
    rcp "${1}" /mnt/nfs/media/tv/
    notify-send "${1} -> ${2} done"
}

pc() {
    python -c "print(${1})"
}

mountall() {
    tr -s ' ' < /etc/fstab|cut -d ' ' -f 2|grep -E '^/mnt/nfs|^/mnt/mergerfs'|sudo xargs -n 1 mount
}

umountall() {
    for i in /mnt/nfs/*; do sudo umount "${i}"; done
}

lumountall() {
    for i in /mnt/nfs/*; do sudo umount -l "${i}"; done
}

kwpo() {
    if [[ "${#}" == 1 ]]; then
        watch kubectl get po -l app.kubernetes.io/name="${1}"
    else
        watch kubectl -n "${1}" get po -l app.kubernetes.io/name="${2}"
    fi
}

klo() {
    if [[ "${#}" == 1 ]]; then
        kubectl logs -l app.kubernetes.io/name="${1}" -f
    else
        kubectl -n "${1}" logs -l app.kubernetes.io/name="${2}" -f
    fi
}

for f in ~/.functions.d/* ; do
    source "${f}"
done

h() {
    bat -r :"${2:-20}" "${1}"
}

vu() {
    mpv --demuxer-lavf-format=video4linux2 --demuxer-lavf-o-set=input_format=mjpeg av://v4l2:/dev/video0
}

portcheck() {
    if [[ "${#}" -lt 2 ]] ; then
        echo "Error: host and port needed"
        return 1
    fi

    while ! nc -vz "${1}" "${2}" ; do sleep 1 ; done
}

flipdir() {
    orig="${1}"

    if [[ "$(wc -w <<< "${orig}")" -ne 2 ]] ; then
        echo "Error: function only works with two words" >&2
        return 1
    fi

    read -r a b <<< "${orig}"
    new="${b} ${a}"

    mkdir -p "${new}"/.thumbs
    mv "${orig}"/.thumbs/* "${new}"/.thumbs/
    mv "${orig}"/* "${new}"/

    rmdir "${orig}"/.thumbs
    rmdir "${orig}"
}

uzd() { unzip -d "${1%.zip}" "${1}" ; }

cb() {
    if [[ "${#}" -gt 0 ]] ; then
        dir="$(grep "^${1}:" ~/.local/share/lf/marks)"
    else
        dir="$(grep -E "^[a-zA-Z0-9]:" ~/.local/share/lf/marks | fzf +m --layout=reverse-list)"
    fi

    if [[ -n "${dir}" ]] ; then
        dir="$(cut -d : -f 2 <<< "${dir}")"
        cd "${dir}"
    fi
}
